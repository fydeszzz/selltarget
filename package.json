{
  "name": "stock-calculator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "author": "Ricy Hsu",
  "description": "Sell-target calculator: enter a stock, amount, and goal, see the price you should sell at.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 5173",
    "electron": "electron .",
    "app:start": "vite build && electron .",
    "app:build": "vite build && electron-builder --win --config.directories.output=%USERPROFILE%/Desktop/SellSignal-build"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "vite": "^6.0.7"
  },
  "build": {
    "appId": "com.ricyhsu.sellsignal",
    "productName": "SellSignal",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "icon.png"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SellSignal"
    },
    "portable": {
      "artifactName": "SellSignal-portable.exe"
    }
  }
}
